# Server-only Neon and Auth.js configuration.
DATABASE_URL=
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
SUPER_ADMIN_BOOTSTRAP_EMAIL=
SUPER_ADMIN_BOOTSTRAP_NAME=

# Full-label v3.2 is applied only to an isolated Neon test branch first.
PUSTAKAOBAT_TEST_DATABASE_URL=

# Private S3-compatible object storage (Cloudflare R2, AWS S3, etc.).
PUSTAKAOBAT_OBJECT_ENDPOINT=
PUSTAKAOBAT_OBJECT_REGION=auto
PUSTAKAOBAT_OBJECT_ACCESS_KEY_ID=
PUSTAKAOBAT_OBJECT_SECRET_ACCESS_KEY=
PUSTAKAOBAT_OBJECT_BUCKET=
PUSTAKAOBAT_OBJECT_FORCE_PATH_STYLE=false

# Optional private Worker reader. When set, this is preferred over the direct
# S3-compatible endpoint so the R2 bucket remains private.
PUSTAKAOBAT_OBJECT_READER_URL=
PUSTAKAOBAT_OBJECT_READER_TOKEN=
