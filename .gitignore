# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local WHO source files and generated import payloads
/data/imports/who/incoming/*
!/data/imports/who/incoming/.gitkeep
/data/imports/who/prepared/*
!/data/imports/who/prepared/.gitkeep
__pycache__/
*.py[cod]

# Monograph v2.2 handoff contains raw source evidence. Keep it local and import
# it only into the authenticated Neon staging tables.
/data/imports/website_export/
/data/imports/apoteq_website_export_v2_2_codex.zip
